{# templates/components/datatable/actions_cell.html.twig #}
<td class="text-center">
    <div class="btn-group" role="group" aria-label="Actions pour l'élément {{ item.id }}">
        {% if showRoute %}
            <a 
                href="{{ path(showRoute, {id: item.id}) }}" 
                class="btn btn-sm btn-outline-info"
                title="Voir"
                aria-label="Voir l'élément {{ item.id }}"
            >
                <i class="bi bi-eye" aria-hidden="true"></i>
            </a>
        {% endif %}
        {% if editRoute %}
            <a 
                href="{{ path(editRoute, {id: item.id}) }}" 
                class="btn btn-sm btn-outline-warning"
                title="Modifier"
                aria-label="Modifier l'élément {{ item.id }}"
            >
                <i class="bi bi-pencil" aria-hidden="true"></i>
            </a>
        {% endif %}
        {% if deleteRoute %}
            <button 
                type="button"
                class="btn btn-sm btn-outline-danger"
                title="Supprimer"
                aria-label="Supprimer l'élément {{ item.id }}"
                data-action="live#action"
                data-live-action-param="deleteItem"
                data-live-id-param="{{ item.id }}"
                data-bs-toggle="modal"
                data-bs-target="#confirmDeleteModal"
                data-item-id="{{ item.id }}"
            >
                <i class="bi bi-trash" aria-hidden="true"></i>
            </button>
        {% endif %}
    </div>
</td>